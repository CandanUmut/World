# ---------------------------------------------------------------------------
# World — environment configuration (all optional; the app runs with none set)
# Copy to `.env` and fill in what you need.
# ---------------------------------------------------------------------------

# Fast OSM geometry source (recommended). URL of a baked PMTiles archive
# (OpenMapTiles schema, e.g. produced by Planetiler). Can be:
#   - a GitHub *Release* asset (<=2GB, supports HTTP range requests), or
#   - a file you place in /public (served at e.g. /world/region.pmtiles), or
#   - any host that supports range requests + CORS (Cloudflare R2, S3, ...).
# Without this, the app falls back to the slow keyless Overpass API (small area).
VITE_PMTILES_URL=

# Alternative: an XYZ vector-tile (MVT) URL template for go-anywhere coverage
# against a hosted vector-tile service (OpenMapTiles schema).
# Example: https://example.com/tiles/{z}/{x}/{y}.pbf
VITE_MVT_URL=

# Optional: a free Cesium ion token unlocks higher-quality terrain and the
# global Cesium OSM Buildings layer. The app works fully WITHOUT this.
# Get a free token at https://cesium.com/ion/ and restrict it by referrer.
VITE_CESIUM_ION_TOKEN=

# Optional: override the GitHub Pages base path if you fork to a different
# repo name. The build uses a relative base by default, so this is rarely needed.
# VITE_BASE=/your-repo/
